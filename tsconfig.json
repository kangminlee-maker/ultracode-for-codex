{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"]
  },
  "include": [
    "src/ultracode-install-guide.ts",
    "src/cli.ts",
    "src/settings.ts",
    "src/runtime/package-info.ts",
    "src/codex/**/*.ts",
    "src/runtime/**/*.ts"
  ]
}
